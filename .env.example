# Copy to .env and fill in values. Never commit .env.

# ─── Market Data ──────────────────────────────────────────────────────
# Financial Modeling Prep — Premium recommended for live runs.
# Sign up: https://site.financialmodelingprep.com/
FMP_API_KEY=
MARKET_API_PROVIDER=fmp                 # fmp | polygon | mock

# Polygon (optional alternative to FMP for news / aggregates)
# Sign up: https://polygon.io/
POLYGON_API_KEY=

# ─── Macro Regime ─────────────────────────────────────────────────────
# Federal Reserve Economic Data — free, requires key.
# Sign up: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ─── Data Mode ────────────────────────────────────────────────────────
# mock     = use sample JSON files (default; no API keys required)
# live     = use real APIs (requires keys above)
# backtest = point-in-time replay mode for historical decisions
DATA_MODE=mock
USE_MOCK_DATA=true

# ─── LLM Provider ─────────────────────────────────────────────────────
# Active provider for the agent stack. Anthropic Haiku 4.5 is the
# canonical model used in all paper results.
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic                  # anthropic | stub
ANTHROPIC_HARD_STOP_USD=                # optional cost cap (e.g. 25.00)

# ─── Alternative Data Sources ─────────────────────────────────────────
# GitHub Public adapter — anonymous works (60 req/hr); token gives 5000/hr.
GITHUB_TOKEN=

# Reddit adapter (currently NOT WIRED — §10.13 anti-pollution exclusion).
# Listed here only because legacy adapter scaffolding still reads the env.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=alt_data_agentic/1.0

# ─── SEC EDGAR ────────────────────────────────────────────────────────
# Required by SEC fair-access policy. Use your real name + email.
SEC_USER_AGENT=YourName your@email.com

# ─── Backtest / Replay Controls ───────────────────────────────────────
# Optional path overrides for the agent runner. Defaults are baked into
# src/agents/runner.py.
ADAS_CSV_PATH=
ABLATION_DISABLE_ADAS=                  # set to "1" to disable ADaS in a cell

# ─── Stub / Test Controls ─────────────────────────────────────────────
# When set to "1", forces all adapters to return deterministic stub
# payloads. Required for the regression-hash test.
STUB_MODE=

# ─── System ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DASHBOARD_PORT=5000
